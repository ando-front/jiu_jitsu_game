# Git LFS tracking for large binary assets.
# See src/prototype/ue5/README.md §2.2 for setup instructions.
# Before the first binary commit, run `git lfs install` in your working tree.

# UE5 asset & map files
*.uasset  filter=lfs diff=lfs merge=lfs -text
*.umap    filter=lfs diff=lfs merge=lfs -text

# Art / mocap
*.fbx     filter=lfs diff=lfs merge=lfs -text
*.exr     filter=lfs diff=lfs merge=lfs -text
*.hdr     filter=lfs diff=lfs merge=lfs -text
*.tga     filter=lfs diff=lfs merge=lfs -text
*.psd     filter=lfs diff=lfs merge=lfs -text

# Audio
*.wav     filter=lfs diff=lfs merge=lfs -text
*.ogg     filter=lfs diff=lfs merge=lfs -text

# Video (cinematics, capture)
*.mp4     filter=lfs diff=lfs merge=lfs -text
*.mov     filter=lfs diff=lfs merge=lfs -text

# Binary archives occasionally committed for reference
*.zip     filter=lfs diff=lfs merge=lfs -text

# Enforce LF for UE5 source / config for Windows ↔ Mac / Linux sanity
*.cpp  text eol=lf
*.h    text eol=lf
*.cs   text eol=lf
*.ini  text eol=lf
*.md   text eol=lf

# Unity text serialization formats (Force Text mode)
*.unity      text eol=lf
*.prefab     text eol=lf
*.asset      text eol=lf
*.asmdef     text eol=lf
*.asmref     text eol=lf
*.meta       text eol=lf
*.inputactions text eol=lf

# Unity binary assets that can grow large
*.unitypackage filter=lfs diff=lfs merge=lfs -text
